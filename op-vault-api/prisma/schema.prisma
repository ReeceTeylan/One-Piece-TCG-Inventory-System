// ============================================================
// OP-Vault — Prisma schema (PostgreSQL)
// 16 models: Users, Customers, RawCards, SlabCards, Sales,
// SaleItems, Shipments, ShipmentItems, InventoryLogs,
// RestockLogs, PriceHistory, Favorites, ActivityLogs,
// Settings, Notifications, CardImages
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------- ENUMS ----------------------
enum Role         { OWNER STAFF }
enum ItemType     { RAW SLAB }
enum StockStatus  { AVAILABLE LOW OUT SOLD }
enum SaleStatus   { PAID PARTIAL UNPAID CANCELLED REFUNDED }
enum ShipStatus   { TO_PACK READY SHIPPED DELIVERED CANCELLED }
enum Courier      { LBC JNT LALAMOVE MEETUP OTHER }
enum InvAction    { CREATE RESTOCK SALE CANCEL_SALE ADJUST PRICE_CHANGE }
enum NotifType    { LOW_STOCK OUT_OF_STOCK SALE SHIPMENT SYSTEM }
enum PaymentMethod{ CASH GCASH BANK_TRANSFER MAYA OTHER }

// ---------------------- USERS ----------------------
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  fullName           String
  role               Role      @default(STAFF)
  isActive           Boolean   @default(true)
  hashedRefreshToken String?
  sales              Sale[]
  restockLogs        RestockLog[]
  inventoryLogs      InventoryLog[]
  activityLogs       ActivityLog[]
  favorites          Favorite[]
  notifications      Notification[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([role])
  @@map("users")
}

// -------------------- CUSTOMERS --------------------
model Customer {
  id            String   @id @default(cuid())
  name          String
  facebookName  String?
  contactNumber String?
  notes         String?
  sales         Sale[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@map("customers")
}

// -------------------- RAW CARDS --------------------
model RawCard {
  id           String      @id @default(cuid())
  name         String
  cardNumber   String
  setName      String
  character    String?
  color        String?
  rarity       String      // C, UC, R, SR, SEC, PSEC, SP, PSR, PR, Promo, Leader, PL, PC or custom
  quantity     Int         @default(0)
  buyCost      Decimal     @db.Decimal(12, 2)
  postedPrice  Decimal     @db.Decimal(12, 2)
  avgSellPrice Decimal?    @db.Decimal(12, 2)
  status       StockStatus @default(AVAILABLE)
  notes        String?
  isPinned     Boolean     @default(false)
  totalSold    Int         @default(0)
  lastSoldAt   DateTime?
  images       CardImage[]
  saleItems    SaleItem[]
  restockLogs  RestockLog[]
  inventoryLogs InventoryLog[]
  favorites    Favorite[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Duplicate-detection key
  @@unique([cardNumber, setName, rarity], name: "rawCardIdentity")
  @@index([status])
  @@index([quantity])
  @@index([rarity])
  @@index([name])
  @@map("raw_cards")
}

// -------------------- SLAB CARDS -------------------
model SlabCard {
  id             String      @id @default(cuid())
  name           String
  cardNumber     String?
  setName        String?
  character      String?
  color          String?
  rarity         String?
  gradingCompany String      // PSA, BGS, CGC, SGC
  slabNumber     String      @unique // certification number — globally unique
  grade          Decimal     @db.Decimal(3, 1)
  buyCost        Decimal     @db.Decimal(12, 2)
  sellPrice      Decimal     @db.Decimal(12, 2)
  status         StockStatus @default(AVAILABLE)
  notes          String?
  isPinned       Boolean     @default(false)
  soldAt         DateTime?
  images         CardImage[]
  saleItems      SaleItem[]
  favorites      Favorite[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([grade])
  @@index([gradingCompany])
  @@index([name])
  @@map("slab_cards")
}

// --------------------- SALES -----------------------
model Sale {
  id           String     @id @default(cuid())
  reference    String     @unique // human-facing e.g. SALE-1002
  customer     Customer   @relation(fields: [customerId], references: [id])
  customerId   String
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  items        SaleItem[]
  shipment     Shipment?
  payments     Payment[]
  subtotal     Decimal    @db.Decimal(12, 2)
  discount     Decimal    @db.Decimal(12, 2) @default(0)
  shippingFee  Decimal    @db.Decimal(12, 2) @default(0)
  grandTotal   Decimal    @db.Decimal(12, 2)
  amountPaid   Decimal    @db.Decimal(12, 2) @default(0)
  totalProfit  Decimal    @db.Decimal(12, 2)
  status       SaleStatus @default(UNPAID)
  notes        String?
  cancelledAt  DateTime?
  refundedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([createdAt])
  @@index([customerId])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id         String   @id @default(cuid())
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId     String
  itemType   ItemType
  rawCard    RawCard? @relation(fields: [rawCardId], references: [id])
  rawCardId  String?
  slab       SlabCard? @relation(fields: [slabId], references: [id])
  slabId     String?
  nameSnapshot String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(12, 2) // editable at sale time
  unitCost   Decimal  @db.Decimal(12, 2) // immutable cost snapshot
  lineProfit Decimal  @db.Decimal(12, 2)

  @@index([saleId])
  @@index([rawCardId])
  @@index([slabId])
  @@map("sale_items")
}

// -------------------- SHIPMENTS --------------------
model Shipment {
  id             String         @id @default(cuid())
  sale           Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId         String         @unique
  courier        Courier
  status         ShipStatus     @default(TO_PACK)
  shippingFee    Decimal        @db.Decimal(12, 2) @default(0)
  totalValue     Decimal        @db.Decimal(12, 2) @default(0)
  trackingNumber String?
  dateShipped    DateTime?
  dateDelivered  DateTime?
  items          ShipmentItem[]
  events         ShipmentEvent[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@map("shipments")
}

model ShipmentItem {
  id           String   @id @default(cuid())
  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId   String
  nameSnapshot String
  quantity     Int      @default(1)

  @@index([shipmentId])
  @@map("shipment_items")
}

// ------------------ INVENTORY LOGS -----------------
model InventoryLog {
  id         String    @id @default(cuid())
  itemType   ItemType
  rawCard    RawCard?  @relation(fields: [rawCardId], references: [id])
  rawCardId  String?
  slabId     String?
  action     InvAction
  quantityDelta Int    @default(0)
  quantityAfter Int?
  reference  String?   // e.g. sale reference
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  createdAt  DateTime  @default(now())

  @@index([itemType])
  @@index([rawCardId])
  @@index([createdAt])
  @@map("inventory_logs")
}

// ------------------- RESTOCK LOGS ------------------
model RestockLog {
  id            String   @id @default(cuid())
  rawCard       RawCard  @relation(fields: [rawCardId], references: [id], onDelete: Cascade)
  rawCardId     String
  quantityAdded Int
  buyCost       Decimal  @db.Decimal(12, 2)
  datePurchased DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  createdAt     DateTime @default(now())

  @@index([rawCardId])
  @@map("restock_logs")
}

// ------------------ PRICE HISTORY ------------------
model PriceHistory {
  id        String   @id @default(cuid())
  itemType  ItemType
  itemId    String
  field     String   // postedPrice | sellPrice | buyCost
  oldValue  Decimal  @db.Decimal(12, 2)
  newValue  Decimal  @db.Decimal(12, 2)
  changedAt DateTime @default(now())

  @@index([itemType, itemId])
  @@map("price_history")
}

// -------------------- FAVORITES --------------------
model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  itemType  ItemType
  rawCard   RawCard? @relation(fields: [rawCardId], references: [id], onDelete: Cascade)
  rawCardId String?
  slab      SlabCard? @relation(fields: [slabId], references: [id], onDelete: Cascade)
  slabId    String?
  createdAt DateTime @default(now())

  @@unique([userId, rawCardId])
  @@unique([userId, slabId])
  @@map("favorites")
}

// ------------------ ACTIVITY LOGS ------------------
model ActivityLog {
  id         String   @id @default(cuid())
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  action     String   // e.g. "raw-card.create"
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// --------------------- SETTINGS --------------------
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ------------------ NOTIFICATIONS ------------------
model Notification {
  id        String    @id @default(cuid())
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?
  type      NotifType
  title     String
  body      String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ------------------- CARD IMAGES -------------------
model CardImage {
  id        String   @id @default(cuid())
  itemType  ItemType
  rawCard   RawCard? @relation(fields: [rawCardId], references: [id], onDelete: Cascade)
  rawCardId String?
  slab      SlabCard? @relation(fields: [slabId], references: [id], onDelete: Cascade)
  slabId    String?
  url       String
  storageKey String
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([rawCardId])
  @@index([slabId])
  @@map("card_images")
}

// --------------------- PAYMENTS --------------------
model Payment {
  id        String        @id @default(cuid())
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  note      String?
  userId    String?
  createdAt DateTime      @default(now())

  @@index([saleId])
  @@map("payments")
}

// ---------------- SHIPMENT TIMELINE ----------------
model ShipmentEvent {
  id         String     @id @default(cuid())
  shipment   Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId String
  status     ShipStatus
  note       String?
  createdAt  DateTime   @default(now())

  @@index([shipmentId])
  @@map("shipment_events")
}
