# ================= OP-Vault PRODUCTION ENV =================
NODE_ENV=production
PORT=4000

# Public origin of the FRONTEND (for CORS). Comma-separate if multiple.
CORS_ORIGIN=https://app.your-domain.com

# Public origin of THIS API (used to build absolute image URLs)
PUBLIC_URL=https://api.your-domain.com

# ---- Database (use a managed Postgres or a locked-down instance) ----
DATABASE_URL="postgresql://opvault:CHANGE_ME_STRONG@db-host:5432/opvault?schema=public&sslmode=require"

# ---- JWT secrets: generate with `openssl rand -base64 48` (DO NOT reuse) ----
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM
JWT_REFRESH_TTL=7d

# ---- Uploads ----
UPLOAD_DIR=/var/lib/opvault/uploads     # persistent volume, NOT inside the container layer

# ---- Store defaults (seeded once) ----
STORE_NAME=OP-Vault TCG
CURRENCY=PHP
LOW_STOCK_THRESHOLD=3
DEFAULT_SHIPPING_FEE=80

# SECURITY CHECKLIST before go-live:
#  - Rotate the seeded owner/staff passwords immediately after first login.
#  - Secrets come from your platform's secret store, never committed.
#  - DB reachable only from the API's private network.
#  - Run behind HTTPS (reverse proxy / load balancer terminating TLS).
